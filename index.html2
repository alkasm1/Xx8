<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>ALM Multi-QR - الإصدار الذكي</title>
    
    <!-- Fonts & Icons -->
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">

    <style>
        :root { --primary: #0BA37F; --secondary: #2c7da0; --bg: #f4f7f6; }
        body { font-family: 'Cairo', sans-serif; background-color: var(--bg); margin: 0; padding: 0; direction: rtl; }
        
        header { background: var(--primary); color: white; padding: 15px; text-align: center; font-size: 20px; font-weight: bold; box-shadow: 0 2px 5px rgba(0,0,0,0.1); }
        
        .nav-tabs { display: flex; background: white; border-bottom: 1px solid #ddd; position: sticky; top: 0; z-index: 100; }
        .tab-btn { flex: 1; padding: 15px; border: none; background: none; font-family: 'Cairo'; font-size: 16px; color: #666; cursor: pointer; border-bottom: 3px solid transparent; }
        .tab-btn.active { color: var(--primary); border-bottom-color: var(--primary); font-weight: bold; }

        .container { padding: 15px; padding-bottom: 100px; max-width: 600px; margin: auto; }
        .tab-content { display: none; }
        .tab-content.active { display: block; }

        .card { background: white; border-radius: 15px; padding: 15px; margin-bottom: 15px; box-shadow: 0 4px 6px rgba(0,0,0,0.05); }
        h3 { font-size: 17px; margin-top: 0; color: var(--primary); margin-bottom: 10px; }
        
        textarea, input { width: 100%; padding: 12px; margin: 8px 0; border: 1px solid #ddd; border-radius: 10px; box-sizing: border-box; font-family: 'Cairo'; }
        
        button { width: 100%; padding: 12px; background: var(--primary); color: white; border: none; border-radius: 10px; font-size: 16px; font-weight: bold; cursor: pointer; transition: 0.3s; margin-top: 5px; }
        button:active { transform: scale(0.98); }
        .btn-outline { background: transparent; color: var(--primary); border: 2px solid var(--primary); }

        /* QR Results Styles */
        .qr-item { background: white; padding: 15px; border-radius: 15px; margin-bottom: 20px; text-align: center; border: 1px solid #eee; }
        .qr-canvas-holder { display: flex; justify-content: center; margin: 15px 0; padding: 10px; background: #fff; }
        .qr-actions { display: flex; gap: 10px; }
        .qr-actions button { flex: 1; font-size: 14px; padding: 10px; margin-top: 0; }
        .btn-save { background: #444; }
        .btn-share { background: #007bff; }

        /* Scanner */
        #scan-btn { position: fixed; bottom: 20px; left: 20px; width: 60px; height: 60px; border-radius: 50%; background: var(--primary); color: white; font-size: 24px; display: flex; align-items: center; justify-content: center; box-shadow: 0 4px 10px rgba(0,0,0,0.3); z-index: 200; }
        #reader-container { display: none; position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: #000; z-index: 1000; }
        .close-scanner { position: absolute; top: 20px; right: 20px; color: white; font-size: 30px; z-index: 1001; }

        .status { font-size: 13px; color: #666; text-align: center; margin: 10px 0; }
    </style>

    <!-- Libraries -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/lz-string/1.4.4/lz-string.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdf.js/2.16.105/pdf.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/mammoth/1.4.2/mammoth.browser.min.js"></script>
    <script src="https://unpkg.com/html5-qrcode"></script>
</head>
<body>

<header>ALM Multi-QR Smart</header>

<div class="nav-tabs">
    <button class="tab-btn active" onclick="showTab('encode')">إنشاء باركود</button>
    <button class="tab-btn" onclick="showTab('decode')">فك التشفير</button>
</div>

<div class="container">
    <!-- Encoding Tab -->
    <div id="encode-tab" class="tab-content active">
        <div class="card">
            <h3>المحتوى</h3>
            <textarea id="inputText" rows="4" placeholder="اكتب النص هنا..."></textarea>
            <label style="font-size: 12px;">أو استخرج من ملف (PDF / Word):</label>
            <input type="file" id="fileInput" accept=".pdf,.docx">
            <input id="userKey" type="number" placeholder="مفتاح التشفير" value="123456789">
            <button onclick="startSmartEncoding()">تحويل (بأقل عدد من الأكواد)</button>
            <div id="status" class="status"></div>
        </div>
        <div id="qrResults"></div>
    </div>

    <!-- Decoding Tab -->
    <div id="decode-tab" class="tab-content">
        <div class="card">
            <h3>فك التشفير من الصور</h3>
            <p style="font-size: 12px; color: #888;">اختر جميع الصور الخاصة بالكتاب دفعة واحدة:</p>
            <input type="file" id="qrFiles" accept="image/*" multiple>
            <button onclick="decodeImages()">بدء معالجة الصور</button>
        </div>
        <div class="card">
            <h3>النص المستخرج:</h3>
            <div id="finalOutput" style="white-space: pre-wrap; font-size: 14px; background: #f9f9f9; padding: 10px; border-radius: 10px; min-height: 100px;"></div>
            <button onclick="copyToClipboard()" id="copyBtn" style="display:none; background: #555; margin-top: 10px;"><i class="fas fa-copy"></i> نسخ النص</button>
        </div>
    </div>
</div>

<div id="scan-btn" onclick="openScanner()"><i class="fas fa-camera"></i></div>

<div id="reader-container">
    <span class="close-scanner" onclick="closeScanner()">&times;</span>
    <div id="reader"></div>
</div>

<script>
    /* --- ALM Core Engine --- */
    const B = 32, LMAX = 12, f0 = 100000n, df = 1n;
    const indexToChar = {0:"",1:"ا",2:"ب",3:"ت",4:"ث",5:"ج",6:"ح",7:"خ",8:"د",9:"ذ",10:"ر",11:"ز",12:"س",13:"ش",14:"ص",15:"ض",16:"ط",17:"ظ",18:"ع",19:"غ",20:"ف",21:"ق",22:"ك",23:"ل",24:"م",25:"ن",26:"ه",27:"و",28:"ي",29:"ء"};
    const charToIndex = Object.fromEntries(Object.entries(indexToChar).map(([i,ch]) => [ch, parseInt(i)]));

    function normalizeArabic(s) {
        return (s || "").replace(/[إأآ]/g, "ا").replace(/ى/g, "ي").replace(/ؤ/g, "و").replace(/ئ/g, "ي").replace(/ة/g, "ه").replace(/[^ءاأإآبتثجحخدذرزسشصضطظعغفقكلمنهوي\s]/g, "");
    }

    function encodeChunk(text, key) {
        return text.split(/\s+/).map(w => {
            let c = new Array(LMAX).fill(0);
            let chars = w.slice(0, LMAX).split('').reverse();
            for(let i=0; i<chars.length; i++) c[i] = charToIndex[chars[i]] || 0;
            let C = 0n;
            for(let i=0; i<LMAX; i++) C += BigInt(c[i]) * (BigInt(B)**BigInt(i));
            return (C ^ BigInt(key)).toString(36);
        }).join(",");
    }

    function decodeChunk(codesStr, key) {
        return codesStr.split(',').map(code36 => {
            try {
                let C = BigInt(parseInt(code36, 36)) ^ BigInt(key);
                let res = "";
                for(let i=0; i<LMAX; i++) {
                    res = (indexToChar[Number(C % BigInt(B))] || "") + res;
                    C /= BigInt(B);
                }
                return res;
            } catch(e) { return ""; }
        }).join(" ");
    }

    /* --- File Handling --- */
    async function extractText(file) {
        if (file.type === "application/pdf") {
            const pdf = await pdfjsLib.getDocument({ data: await file.arrayBuffer() }).promise;
            let t = "";
            for (let i = 1; i <= pdf.numPages; i++) {
                const page = await pdf.getPage(i);
                t += (await page.getTextContent()).items.map(it => it.str).join(" ") + " ";
            }
            return normalizeArabic(t);
        } else if (file.name.endsWith(".docx")) {
            const res = await mammoth.extractRawText({ arrayBuffer: await file.arrayBuffer() });
            return normalizeArabic(res.value);
        }
        return "";
    }

    /* --- Smart Encoding Logic (Optimization) --- */
    async function startSmartEncoding() {
        const key = document.getElementById('userKey').value;
        const file = document.getElementById('fileInput').files[0];
        let text = document.getElementById('inputText').value.trim();
        const statusDiv = document.getElementById('status');

        if (file) {
            statusDiv.textContent = "⏳ جاري قراءة الملف...";
            text = await extractText(file);
        }

        if (!text) return alert("أدخل نصاً أولاً");

        statusDiv.textContent = "⏳ جاري تحسين التقسيم...";
        
        // محاولة تقسيم النص لأجزاء كبيرة جداً (3200 حرف)
        let rawChunks = text.match(/.{1,3200}(\s|$)/g) || [text];
        let finalPayloads = [];
        
        for (let chunk of rawChunks) {
            let success = false;
            let current = chunk;
            while (!success && current.length > 10) {
                const encoded = encodeChunk(current, key);
                const compressed = LZString.compressToEncodedURIComponent(encoded);
                const testPayload = `part=0/0|${compressed}`;
                
                // اختبار إذا كان الباركود سيقبل الحجم (الحد الأقصى المريح للجوال هو 2200 حرف مضغوط)
                if (testPayload.length <= 2200) {
                    finalPayloads.push(compressed);
                    success = true;
                } else {
                    // إذا كان كبيراً جداً، نقسمه ونعيد المحاولة
                    current = current.slice(0, Math.floor(current.length * 0.8));
                }
            }
        }

        // عرض النتائج
        const resultsDiv = document.getElementById('qrResults');
        resultsDiv.innerHTML = "";
        finalPayloads.forEach((data, i) => {
            const payload = `part=${i+1}/${finalPayloads.length}|${data}`;
            renderQRCard(payload, i + 1, finalPayloads.length);
        });
        statusDiv.textContent = `✅ تم التوليد: ${finalPayloads.length} باركود فقط.`;
    }

    function renderQRCard(payload, part, total) {
        const div = document.createElement('div');
        div.className = 'qr-item';
        div.innerHTML = `<h3>الجزء ${part} من ${total}</h3><div class="qr-canvas-holder"></div>`;
        
        const actions = document.createElement('div');
        actions.className = 'qr-actions';
        actions.innerHTML = `
            <button class="btn-save" onclick="saveQR(this)"><i class="fas fa-download"></i> حفظ</button>
            <button class="btn-share" onclick="shareQR(this)"><i class="fas fa-share-alt"></i> مشاركة</button>
        `;
        
        new QRCode(div.querySelector('.qr-canvas-holder'), {
            text: payload,
            width: 240,
            height: 240,
            correctLevel: QRCode.CorrectLevel.L
        });
        
        div.appendChild(actions);
        document.getElementById('qrResults').appendChild(div);
    }

    /* --- Save & Share --- */
    function saveQR(btn) {
        const canvas = btn.closest('.qr-item').querySelector('canvas');
        const link = document.createElement('a');
        link.download = `ALM-Part-${Date.now()}.png`;
        link.href = canvas.toDataURL("image/png");
        link.click();
    }

    async function shareQR(btn) {
        const canvas = btn.closest('.qr-item').querySelector('canvas');
        const blob = await (await fetch(canvas.toDataURL())).blob();
        const file = new File([blob], 'qr-alm.png', { type: 'image/png' });
        if (navigator.share) {
            navigator.share({ files: [file], title: 'ALM QR' }).catch(console.error);
        } else {
            alert("المشاركة غير مدعومة في متصفحك، استخدم زر الحفظ.");
        }
    }

    /* --- Decoding --- */
    async function decodeImages() {
        const files = document.getElementById('qrFiles').files;
        const key = document.getElementById('userKey').value;
        if (!files.length) return alert("اختر الصور أولاً");

        const scanner = new Html5Qrcode("reader");
        let resultsMap = new Map();
        let maxPart = 0;

        for (let file of files) {
            try {
                const text = await scanner.scanFile(file, true);
                if (text.includes('|')) {
                    const [header, data] = text.split('|');
                    const partMatch = header.match(/part=(\d+)\/(\d+)/);
                    if (partMatch) {
                        const currentPart = parseInt(partMatch[1]);
                        maxPart = parseInt(partMatch[2]);
                        const decompressed = LZString.decompressFromEncodedURIComponent(data);
                        resultsMap.set(currentPart, decodeChunk(decompressed, key));
                    }
                }
            } catch (e) {}
        }
        
        let fullText = "";
        for (let i = 1; i <= maxPart; i++) {
            fullText += (resultsMap.get(i) || `[الجزء ${i} مفقود] `) + " ";
        }
        document.getElementById('finalOutput').textContent = fullText.trim();
        document.getElementById('copyBtn').style.display = fullText ? 'block' : 'none';
        scanner.clear();
    }

    /* --- UI Helpers --- */
    function showTab(tab) {
        document.querySelectorAll('.tab-content, .tab-btn').forEach(el => el.classList.remove('active'));
        document.getElementById(tab + '-tab').classList.add('active');
        event.currentTarget.classList.add('active');
    }

    function copyToClipboard() {
        navigator.clipboard.writeText(document.getElementById('finalOutput').textContent);
        alert("تم النسخ!");
    }

    let html5QrCode;
    function openScanner() {
        document.getElementById('reader-container').style.display = 'block';
        html5QrCode = new Html5Qrcode("reader");
        html5QrCode.start({ facingMode: "environment" }, { fps: 10, qrbox: 250 }, (decodedText) => {
            document.getElementById('finalOutput').textContent = "محتوى الباركود الممسوح:\n" + decodedText;
            showTab('decode');
            closeScanner();
        });
    }

    function closeScanner() {
        if (html5QrCode) html5QrCode.stop();
        document.getElementById('reader-container').style.display = 'none';
    }
</script>

</body>
</html>
